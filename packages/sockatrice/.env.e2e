# Per-package values for the shared e2e stack at docker/servatrice/.
# Passed to docker-compose via `--env-file .env.e2e`.
# Named `.env.e2e` rather than `.env` so vitest doesn't auto-load it during
# test runs.
# Port 4749 (not 4748) so Sockatrice's stack can run alongside Webatrice's,
# which keeps the canonical 4748.
COMPOSE_PROJECT_NAME=sockatrice-e2e
E2E_SERVATRICE_PORT=4749
