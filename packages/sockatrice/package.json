{
  "name": "@cockatrice/sockatrice",
  "version": "4.1.2",
  "description": "Websocket integration for Servatrice",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seavor/Sockatrice.git"
  },
  "bugs": {
    "url": "https://github.com/seavor/Sockatrice/issues"
  },
  "homepage": "https://github.com/seavor/Sockatrice#readme",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generated": {
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./testing/setup-hooks": {
      "types": "./dist/testing/setup-hooks.d.ts",
      "import": "./dist/testing/setup-hooks.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run proto:generate",
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "npm run test -- --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:coverage": "npm run test:integration -- --coverage",
    "test:e2e:up": "docker compose --env-file ../../.env.e2e --env-file .env.e2e -f ../../docker/servatrice/docker-compose.e2e.yml up -d",
    "test:e2e:down": "docker compose --env-file ../../.env.e2e --env-file .env.e2e -f ../../docker/servatrice/docker-compose.e2e.yml down -v",
    "test:e2e:run": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:run-with-cleanup": "run-s --continue-on-error test:e2e:run test:e2e:down",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "test:e2e": "run-s build test:e2e:up test:e2e:run-with-cleanup",
    "golden": "npm run lint && npm run test && npm run test:integration",
    "golden:coverage": "npm run test:coverage && npm run test:integration:coverage",
    "proto:generate": "npx buf generate",
    "pack": "npm pack"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "dompurify": "^3.4.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.70.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@bufbuild/protoplugin": "^2.11.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.20",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "tsup": "^8.5.1",
    "typescript": "~6.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.4",
    "ws": "^8.18.0"
  },
  "keywords": [],
  "author": ""
}
