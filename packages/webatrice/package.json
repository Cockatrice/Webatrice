{
  "name": "@cockatrice/webatrice",
  "version": "4.0.2",
  "private": true,
  "scripts": {
    "start": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:coverage": "npm run test -- --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:coverage": "npm run test:integration -- --coverage",
    "test:e2e:up": "docker compose --env-file ../../.env.e2e --env-file .env.e2e -f ../../docker/servatrice/docker-compose.e2e.yml up -d",
    "test:e2e:down": "docker compose --env-file ../../.env.e2e --env-file .env.e2e -f ../../docker/servatrice/docker-compose.e2e.yml down -v",
    "test:e2e:install-browsers": "playwright install chromium",
    "test:e2e:install-browsers:linux": "playwright install --with-deps chromium",
    "test:e2e:run": "playwright test",
    "test:e2e:run-with-cleanup": "run-s --continue-on-error test:e2e:run test:e2e:down",
    "test:e2e": "run-s build test:e2e:install-browsers test:e2e:up test:e2e:run-with-cleanup",
    "golden": "npm run lint && npm run test && npm run test:integration",
    "golden:coverage": "npm run lint && npm run test:coverage && npm run test:integration:coverage",
    "prebuild": "node prebuild.js",
    "prestart": "node prebuild.js",
    "translate": "node prebuild.js -i18nOnly"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@cockatrice/datatrice": "^4.1.0",
    "@cockatrice/sockatrice": "^4.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@reduxjs/toolkit": "^2.11.2",
    "crypto-js": "^4.2.0",
    "dexie": "^4.4.2",
    "flag-icons": "^7.5.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-icu": "^2.0.3",
    "intl-messageformat": "^11.2.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "rxjs": "^7.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@mui/types": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/prop-types": "^15.7.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-virtualized-auto-sizer": "^1.0.8",
    "@types/react-window": "^1.8.5",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "fake-indexeddb": "^6.2.5",
    "fs-extra": "^11.3.4",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "ws": "^8.18.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
